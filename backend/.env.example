# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# SQL Server connection (SQL auth — rccp_app login)
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=RCCP_One
DB_USER=rccp_app
DB_PASSWORD=rccp_app_pass

# File upload storage (relative to backend/ directory)
UPLOAD_DIR=./uploads

# JWT — use a long random string, keep secret
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRE_MINUTES=480
