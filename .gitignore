# =============================================================================
# RCCP One — .gitignore
# Python + FastAPI backend, React TypeScript frontend, SQL Server
# =============================================================================

# -----------------------------------------------------------------------------
# Python / FastAPI backend
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/
.env/

# Environment variables — NEVER commit secrets
.env
.env.local
.env.*.local
backend/.env

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
*.cover

# MyPy / Pyright type checking
.mypy_cache/
.dmypy.json

# -----------------------------------------------------------------------------
# Uploaded files — NEVER commit planning data files
# -----------------------------------------------------------------------------
backend/uploads/
uploads/

# -----------------------------------------------------------------------------
# React / Node frontend
# -----------------------------------------------------------------------------
frontend/node_modules/
node_modules/

# Build output
frontend/build/
frontend/dist/
frontend/.next/

# Frontend env
frontend/.env
frontend/.env.local
frontend/.env.*.local

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE / editor
# -----------------------------------------------------------------------------
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# VSCode — keep shared settings, ignore local overrides
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace

# Windsurf / Cursor
.windsurf/
.cursor/

# Claude Code — local IDE settings (machine-specific, not project config)
# Project context lives in CLAUDE.md at the repo root instead
.claude/
**/.claude/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Alembic (keep migration scripts, ignore compiled cache)
# -----------------------------------------------------------------------------
db/migrations/versions/__pycache__/
